    {
      "id": "ayFmWR4M_heC0wRuUteYW",
      "type": "text",
      "x": 227.46943400484508,
      "y": 486.452380803119,
      "width": 644.4000244140625,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
