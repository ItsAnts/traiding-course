      "isDeleted": false,
      "boundElements": [],
      "updated": 1775978302549,
      "link": null,
      "locked": false,
      "text": "цена = (новости + ожид. участ + эконом. данные + действие крупных участников)",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "цена = (новости + ожид. участ + эконом. данные + действие крупных участников)",
      "autoResize": true,
      "lineHeight": 1.25
    },
