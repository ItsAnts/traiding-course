      "seed": 1474246779,
      "version": 128,
      "versionNonce": 2108603355,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775978161289,
      "link": null,
      "locked": false,
      "text": "Цена движется чаще:\n- в тренде\n- в диапазоне\n\nНе движется случайно постоянно",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Цена движется чаще:\n- в тренде\n- в диапазоне\n\nНе движется случайно постоянно",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5uz7gnWhlMydPS-95RsRy",
      "type": "text",
      "x": 587.167057427142,
      "y": 119.71685980359302,
      "width": 1631,
      "height": 45,
      "angle": 0,
