      "boundElements": [],
      "updated": 1775978589918,
      "link": null,
      "locked": false,
      "text": "Поведение участников повторяется\n\nФормируются:\n- паттерны\n- модели\n- реакция на уровни",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
