      "isDeleted": false,
      "boundElements": [],
      "updated": 1775979367310,
      "link": null,
      "locked": false,
      "text": "История повторяется",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "История повторяется",
