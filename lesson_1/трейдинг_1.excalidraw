      "updated": 1774677701274,
      "link": null,
      "locked": false,
      "text": "try:\n    age: int = int(input(\"Введите ваш возраст\"))\n    \n    if age < 0:\n        raise ValueError\n    elif age < 13:\n        print(\"Ты ребёнок\")\n    elif 13 <= age <= 17:\n        print(\"Ты подросток\")\n    else:\n        print(\"Ты взрослый\")\nexcept ValueError:\n    print(\"Ошибка ввода\")",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "try:\n    age: int = int(input(\"Введите ваш возраст\"))\n    \n    if age < 0:\n        raise ValueError\n    elif age < 13:\n        print(\"Ты ребёнок\")\n    elif 13 <= age <= 17:\n        print(\"Ты подросток\")\n    else:\n        print(\"Ты взрослый\")\nexcept ValueError:\n    print(\"Ошибка ввода\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
