    {
      "id": "0iqHO6tkjKpFNDJ15GBgN",
      "type": "text",
      "x": 1569.25,
      "y": 105.5,
      "width": 1295.449951171875,
      "height": 490,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bG2",
      "roundness": null,
      "seed": 1736796454,
      "version": 906,
      "versionNonce": 809892730,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774677701274,
      "link": null,
      "locked": false,
      "text": "1. МЫ ЗАПРАШИВАЕМ ЧЕРЕЗ ФУНКЦИЮ\ninput() у пользователя значение типа строка\nчерез ввод в консоль и записываем данное значение в \nпеременную role.\n\n2. Мы применяем конструкцию match/case где \nмы сопоставляем выражение role и шаблонами case такими как:\n- \"admin\"\n- \"editor\"\n- \"viewer\"\n- и если никакой выше не подошел то используем _\n\n3. При если выражение сопвпадает с шаблоном то выполняются инструкции, которые\nописаны в шаблоне.",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. МЫ ЗАПРАШИВАЕМ ЧЕРЕЗ ФУНКЦИЮ\ninput() у пользователя значение типа строка\nчерез ввод в консоль и записываем данное значение в \nпеременную role.\n\n2. Мы применяем конструкцию match/case где \nмы сопоставляем выражение role и шаблонами case такими как:\n- \"admin\"\n- \"editor\"\n- \"viewer\"\n- и если никакой выше не подошел то используем _\n\n3. При если выражение сопвпадает с шаблоном то выполняются инструкции, которые\nописаны в шаблоне.",
      "autoResize": true,
      "lineHeight": 1.25
    },
