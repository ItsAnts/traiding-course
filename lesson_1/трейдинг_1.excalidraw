    {
      "id": "Bg_gcdLxqod7VTQY7U1cD",
      "type": "text",
      "x": 1092.1361114415288,
      "y": 3086.692521125608,
      "width": 1392.9000244140625,
      "height": 840,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGW",
      "roundness": null,
      "seed": 891501222,
      "version": 1111,
      "versionNonce": 1055606822,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774677701274,
      "link": null,
      "locked": false,
      "text": "balance: int = 100\naction: str = input(\"Введите действие 'deposit' | 'withdraw': \")\n\nmatch action:\n    case \"deposit\":\n        try:\n            sum_operation: float = float(input(\"Введите сумму пополнения: \"))\n            if sum_operation < 0:\n                raise ValueError:\n            balance += sum_peration\n        except:\n            print(\"Ошибка суммы пополнения\")\n    case \"withdraw\":\n        try:\n          sum_operation: float = float(input(\"Введите сумму cнятия: \"))\n          if sum_operation > balance:\n              raise ValueError:\n          balance -= sum_operation\n          print(\"С баланса снято {}, текущий баланс: {}\".format(sum_operation, balance))\n        except:\n            print(\"Ошибка суммы снятия\")\n    case _:\n        print(\"Не корректная команда\")\n    ",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "balance: int = 100\naction: str = input(\"Введите действие 'deposit' | 'withdraw': \")\n\nmatch action:\n    case \"deposit\":\n        try:\n            sum_operation: float = float(input(\"Введите сумму пополнения: \"))\n            if sum_operation < 0:\n                raise ValueError:\n            balance += sum_peration\n        except:\n            print(\"Ошибка суммы пополнения\")\n    case \"withdraw\":\n        try:\n          sum_operation: float = float(input(\"Введите сумму cнятия: \"))\n          if sum_operation > balance:\n              raise ValueError:\n          balance -= sum_operation\n          print(\"С баланса снято {}, текущий баланс: {}\".format(sum_operation, balance))\n        except:\n            print(\"Ошибка суммы снятия\")\n    case _:\n        print(\"Не корректная команда\")\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
