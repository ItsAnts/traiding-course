    {
      "id": "JTBbCpuXzVn46ymXE9dek",
      "type": "text",
      "x": 1118.4934270204253,
      "y": 666.389657985143,
      "width": 1097.949951171875,
      "height": 420,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
