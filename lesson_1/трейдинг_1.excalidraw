      "text": "role: str = input(\"Введите вашу роль: \")\n\nmatch role:\n    case \"admin\":\n        print(\"Полный доступ\")\n    case \"editor\":\n        print(\"Редактирование\")\n    case \"viewer\":\n        print(\"Просмотр\")\n    case _:\n        print(\"Нет доступа\")",
