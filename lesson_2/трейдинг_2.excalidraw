      "isDeleted": false,
      "boundElements": [],
      "updated": 1774688368591,
      "link": null,
      "locked": false,
      "text": "Задачи трейдера:\n- Анализ рынка\n- Управление риска\n- Контроль капитала\n- введение статистики торговли\n- Принятия торговых решений",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Задачи трейдера:\n- Анализ рынка\n- Управление риска\n- Контроль капитала\n- введение статистики торговли\n- Принятия торговых решений",
      "autoResize": true,
      "lineHeight": 1.25
    },
