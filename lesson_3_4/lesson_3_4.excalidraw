      "text": "Фондовый рынок",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Фондовый рынок",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qV0Jp2bUo5SrSrP-7Wxsy",
      "type": "text",
      "x": 630.1670175115407,
      "y": 2094.5854708893266,
      "width": 1196.5333251953125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 1439767500,
      "version": 113,
      "versionNonce": 1658312564,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775295416947,
      "link": null,
      "locked": false,
      "text": "Определение - рынок, на котором обращаются ценные бумаги\nкомпаний и государства ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Определение - рынок, на котором обращаются ценные бумаги\nкомпаний и государства ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9dukrj-8u8TPXIg0NARSq",
      "type": "text",
      "x": 631.2591831887052,
      "y": 2193.9725475113014,
      "width": 601.066650390625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
