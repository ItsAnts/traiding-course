      "link": null,
      "locked": false,
      "text": "1. Привлечение капитала",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Привлечение капитала",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
