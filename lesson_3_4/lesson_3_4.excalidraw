      "isDeleted": false,
      "boundElements": null,
      "updated": 1775375269010,
      "link": null,
      "locked": false,
      "text": "Криптовалютный рынок - рынок цифровых активов, функционирующий\nна основе технологии блокчейн",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
