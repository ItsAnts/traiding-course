      "type": "text",
      "x": 633.4435145430353,
      "y": 62.06514568607656,
      "width": 1204,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 1643290228,
      "version": 198,
      "versionNonce": 1585049676,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775292627714,
      "link": null,
      "locked": false,
      "text": "Определение: система экономических отношений в рамках\nкоторых происходит купля-продажа ФИНАНСОВЫХ ИНСТРУМЕНТОВ\nмежду участниками рынка",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Определение: система экономических отношений в рамках\nкоторых происходит купля-продажа ФИНАНСОВЫХ ИНСТРУМЕНТОВ\nмежду участниками рынка",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ZAQKffvI8ubReyFPSiVag",
      "type": "text",
      "x": 645.4573369918455,
