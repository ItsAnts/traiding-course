      "lineHeight": 1.25
    },
    {
      "id": "PfxJcfgvzrm8frBLhKOh0",
      "type": "text",
      "x": 614.8766980312377,
      "y": 1004.6041250790947,
      "width": 920.4666748046875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ao",
      "roundness": null,
      "seed": 160025076,
      "version": 163,
      "versionNonce": 1326427212,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775293353256,
      "link": null,
      "locked": false,
      "text": "Капитал перемещается от:\n- участников с избыточными средствами\n- к участникам нуждающимся в финансирование",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Капитал перемещается от:\n- участников с избыточными средствами\n- к участникам нуждающимся в финансирование",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aekN8SkFG7mIAoRWMmg7q",
      "type": "text",
      "x": 621.0830815337998,
      "y": 1176.0741363939314,
      "width": 425.8666687011719,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
