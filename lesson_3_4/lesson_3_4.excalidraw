    {
      "id": "99qwjthjJyi785I_iL3Cx",
      "type": "text",
      "x": 615.9688637084023,
      "y": 629.9912978116496,
      "width": 1070.2667236328125,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
