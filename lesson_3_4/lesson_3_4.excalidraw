      "roundness": null,
      "seed": 323361780,
      "version": 151,
      "versionNonce": 1734885364,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775295485884,
      "link": null,
      "locked": false,
      "text": "Основные задачи:\n- Привлечение инвестиций\n- Финансирование бизнеса\n- Перераспределение капитала",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Основные задачи:\n- Привлечение инвестиций\n- Финансирование бизнеса\n- Перераспределение капитала",
      "autoResize": true,
      "lineHeight": 1.25
    },
