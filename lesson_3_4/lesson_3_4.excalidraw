      "type": "text",
      "x": 608.3237039682504,
      "y": 954.3645039295247,
      "width": 599.2000122070312,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
