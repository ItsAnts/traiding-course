      "boundElements": [],
      "updated": 1775293226741,
      "link": null,
      "locked": false,
      "text": "2. Перераспределение средств",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Перераспределение средств",
