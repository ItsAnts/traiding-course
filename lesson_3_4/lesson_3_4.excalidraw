      "isDeleted": false,
      "boundElements": [],
      "updated": 1775292749288,
      "link": null,
      "locked": false,
      "text": "Финансовые рынки обеспечивают движение капитала\nмежду:\n- Банки\n- Компании \n- Частные инвесторы\n- Государство ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Финансовые рынки обеспечивают движение капитала\nмежду:\n- Банки\n- Компании \n- Частные инвесторы\n- Государство ",
      "autoResize": true,
      "lineHeight": 1.25
    },
